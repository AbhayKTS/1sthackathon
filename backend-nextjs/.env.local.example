# ─── RevengersHack 2026 — Backend Environment Variables ─────────────────────
# Copy this file to .env.local and fill in all values before running the dev server.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:5173

# ── Firebase Admin — choose ONE form ─────────────────────────────────────────
# Form 1: Single JSON blob (preferred for Vercel deployment)
# FIREBASE_ADMIN_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'

# Form 2: Individual fields
# FIREBASE_ADMIN_PROJECT_ID=your-project-id
# FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Firebase Client SDK (public) ──────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=   # optional

# ── Email Providers (at least one required in production) ─────────────────────
# Postmark (primary) — https://postmarkapp.com
# POSTMARK_SERVER_TOKEN=

# Resend (fallback) — https://resend.com
# RESEND_API_KEY=

EMAIL_FROM=noreply@revengershack.tech
EMAIL_FROM_NAME=RevengersHack

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://revengershack.tech,https://www.revengershack.tech,http://localhost:3000,http://localhost:3001,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:5173

# ── OTP Rate Limiting ─────────────────────────────────────────────────────────
OTP_MAX_PER_HOUR=5
OTP_EXPIRY_MINUTES=10
OTP_MAX_VERIFY_ATTEMPTS=5

# ── Google Sheets Sync ────────────────────────────────────────────────────────
# Service account JSON with Google Sheets API access
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# GOOGLE_SHEET_PPT_ID=          # Sheet ID for PPT submissions
# GOOGLE_SHEET_PROTO_ID=        # Sheet ID for prototype submissions

# ── Cron / Queue Workers ──────────────────────────────────────────────────────
# Secret for /api/internal/* endpoints (generate with: openssl rand -hex 32)
# CRON_SECRET=

MAIL_QUEUE_BATCH_SIZE=20
MAIL_QUEUE_MAX_ATTEMPTS=3
SHEETS_QUEUE_BATCH_SIZE=10
SHEETS_QUEUE_MAX_ATTEMPTS=3

# ── Announcement Broadcast Channels ───────────────────────────────────────────
# Discord webhook URL (from Server Settings → Integrations → Webhooks)
# DISCORD_WEBHOOK_URL=

# WhatsApp API (provider-specific — confirm provider before configuring)
# WHATSAPP_API_TOKEN=
# WHATSAPP_API_URL=
