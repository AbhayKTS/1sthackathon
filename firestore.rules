rules_version = '2';

//
// RevengersHack 2026 — Firestore Security Rules
//
// Architecture: ALL WRITES to sensitive collections happen via the
// backend-nextjs API (Firebase Admin SDK, bypasses these rules).
// These rules defend against direct client SDK attacks.
//
// Roles are stored in users/{uid}.role and validated by the API.
// Client SDK reads must be explicitly permitted here.
//
// Collections:
//   users, teams, invitedTeams, rounds, submissions, sessions,
//   evaluations, leaderboard, announcements, mailQueue, mentorSlots,
//   judges, permissions, activityLogs, auditLogs, settings, googleSheets,
//   otpCodes, otpRateLimits, notifications, emailLogs, tickets
//
// ─── RULE CONVENTIONS ────────────────────────────────────────────────────────
// isAuth()       — has a valid Firebase Auth session
// isAdmin()      — role is admin or super_admin
// isSuperAdmin() — role is super_admin
// isOwnUser(uid) — the authenticated uid matches the target
// isTeamMember() — authenticated user belongs to the team (memberEmails array)
// isTeamLeader() — authenticated user is the team leader
//

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ─────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuth() && getRole() in ['admin', 'super_admin'];
    }

    function isSuperAdmin() {
      return isAuth() && getRole() == 'super_admin';
    }


    function isOwnUser(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ─── Users ────────────────────────────────────────────────────────────────
    // Participants can read their own doc. Admins can read all.
    // Writes are Admin SDK only.

    match /users/{uid} {
      allow read: if isOwnUser(uid) || isAdmin();
      allow write: if false; // Admin SDK only
    }

    // ─── Invited Teams ────────────────────────────────────────────────────────
    // Participants can read the invitedTeam linked to them.
    // Admins can read/write all (for panel display; mutations via API).

    match /invitedTeams/{docId} {
      allow read: if isAdmin() ||
        (isAuth() && resource.data.keys().hasAny(['leaderEmail']) && resource.data.leaderEmail == request.auth.token.email);
      allow write: if false; // Admin SDK only
    }

    // ─── Teams ────────────────────────────────────────────────────────────────
    // Participants can read their own team (matched by memberEmails or leaderId).
    // Admins can read all.

    match /teams/{teamId} {
      allow read: if isAdmin() ||
        (isAuth() && (
          (resource.data.keys().hasAny(['leaderId']) && resource.data.leaderId == request.auth.uid) ||
          (resource.data.keys().hasAny(['memberEmails']) && request.auth.token.email in resource.data.memberEmails)
        ));
      allow write: if false; // Admin SDK only
    }

    // ─── Rounds ───────────────────────────────────────────────────────────────
    // Participants can read Published/Active/Locked/Completed rounds.
    // Draft and Archived rounds are admin-only.
    // allowedTeams is enforced by API, not here (too complex for rules).

    match /rounds/{roundId} {
      allow read: if isAdmin() ||
        (isAuth() && resource.data.keys().hasAny(['isVisible']) && resource.data.isVisible == true &&
         resource.data.status in ['Published', 'Active', 'Locked', 'Evaluation', 'Completed']);
      allow write: if false; // Admin SDK only
    }

    // ─── Submissions ──────────────────────────────────────────────────────────
    // Team leader can read their own submissions.
    // Admins can read all.
    // Writes via API only.

    match /submissions/{submissionId} {
      allow read: if isAdmin() ||
        (isAuth() && resource.data.submittedBy == request.auth.uid);
      allow write: if false; // Admin SDK only
    }

    // ─── Sessions (legacy) ────────────────────────────────────────────────────
    // Legacy sessions collection (from old round.service assignSession)

    match /sessions/{sessionId} {
      allow read: if isAdmin() ||
        (isAuth() && resource.data.teamId != null &&
         exists(/databases/$(database)/documents/teams/$(resource.data.teamId)) &&
         get(/databases/$(database)/documents/teams/$(resource.data.teamId)).data.leaderId == request.auth.uid);
      allow write: if false; // Admin SDK only
    }

    // ─── Mentor Slots ─────────────────────────────────────────────────────────
    // Team can read their slot IF meetLinkVisibleAt has passed for the link,
    // OR if they're reading non-sensitive fields.
    // The time-gate on meetLink is enforced by the API (server-side), not rules.
    // Rules only allow the read — the API strips meetLink if too early.

    match /mentorSlots/{slotId} {
      allow read: if isAdmin() ||
        (isAuth() && resource.data.teamId != null &&
         exists(/databases/$(database)/documents/teams/$(resource.data.teamId)) &&
         get(/databases/$(database)/documents/teams/$(resource.data.teamId)).data.leaderId == request.auth.uid);
      allow write: if false; // Admin SDK only
    }

    // ─── Evaluations ─────────────────────────────────────────────────────────
    // Admins and judges can read evaluations.
    // Participants NEVER have read access to evaluations.
    // Published scores visible via leaderboard subcollection only.

    match /evaluations/{evalId} {
      allow read: if isAdmin() ||
        (isAuth() && getRole() == 'judge');
      allow write: if false; // Admin SDK only
    }

    // ─── Leaderboard ─────────────────────────────────────────────────────────
    // The top-level round doc is readable by all logged-in users if published.
    // The standings subcollection is readable if the round doc isPublished=true.
    // Unpublished leaderboards (isPublished=false) → admin-only.

    match /leaderboard/{roundId} {
      allow read: if isAdmin() ||
        (isAuth() && resource.data.keys().hasAny(['isPublished']) && resource.data.isPublished == true);
      allow write: if false; // Admin SDK only

      match /standings/{teamId} {
        allow read: if isAdmin() ||
          (isAuth() &&
           get(/databases/$(database)/documents/leaderboard/$(roundId)).data.keys().hasAny(['isPublished']) &&
           get(/databases/$(database)/documents/leaderboard/$(roundId)).data.isPublished == true);
        allow write: if false; // Admin SDK only
      }
    }

    // ─── Announcements ────────────────────────────────────────────────────────
    // All authenticated users can read visible announcements.

    match /announcements/{annId} {
      allow read: if isAuth() && resource.data.keys().hasAny(['isVisible']) && resource.data.isVisible == true;
      allow read: if isAdmin(); // Admins see all including hidden
      allow write: if false; // Admin SDK only
    }

    // ─── Mail Queue ───────────────────────────────────────────────────────────
    // Zero client access. Admin SDK only.

    match /mailQueue/{jobId} {
      allow read, write: if false;
    }

    // ─── Email Logs ───────────────────────────────────────────────────────────
    // Admin SDK only.

    match /emailLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ─── Google Sheets Sync Queue ─────────────────────────────────────────────
    // Admin SDK only.

    match /googleSheets/{syncJobId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ─── Judges ───────────────────────────────────────────────────────────────

    match /judges/{judgeId} {
      allow read: if isAdmin();
      allow write: if false; // Admin SDK only
    }

    // ─── Permissions ─────────────────────────────────────────────────────────
    // Super admin can read all. Admins can read their own.

    match /permissions/{userId} {
      allow read: if isSuperAdmin() ||
        (isAdmin() && isOwnUser(userId));
      allow write: if false; // Admin SDK only
    }

    // ─── Settings ─────────────────────────────────────────────────────────────
    // Admins can read platform settings (for admin panel display).
    // Participants cannot read settings (contains internal URLs/tokens).

    match /settings/{key} {
      allow read: if isAdmin();
      allow write: if false; // Admin SDK only
    }

    // ─── Audit Logs ───────────────────────────────────────────────────────────
    // Admin read only. No client writes ever.

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ─── Legacy AuditLogs (capital A, old collection name) ────────────────────
    match /AuditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ─── Activity Logs ────────────────────────────────────────────────────────
    // Admin read only. Writes via Admin SDK only.

    match /activityLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ─── OTP Codes ────────────────────────────────────────────────────────────
    // Zero client access. Admin SDK only.

    match /otpCodes/{docId} {
      allow read, write: if false;
    }

    // ─── OTP Rate Limits ─────────────────────────────────────────────────────
    // Zero client access. Admin SDK only.

    match /otpRateLimits/{email} {
      allow read, write: if false;
    }

    // ─── Notifications ────────────────────────────────────────────────────────
    // Users can read their own notifications. Writes via Admin SDK only.

    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow write: if false; // Admin SDK only
    }

    // ─── Tickets ─────────────────────────────────────────────────────────────
    // Users can read/create their own tickets. Admin can read all.

    match /tickets/{ticketId} {
      allow read: if isAdmin() ||
        (isAuth() && resource.data.keys().hasAny(['createdBy']) && resource.data.createdBy == request.auth.uid);
      allow create: if isAuth() &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.status == 'open' &&
        request.resource.data.message.size() > 0 &&
        request.resource.data.message.size() <= 2000;
      allow update: if false; // Replies via Admin SDK
    }

    // ─── Dead Collections (read-only for migration) ───────────────────────────
    // These will be deleted after migration is confirmed.

    match /hackathondata/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /teamData2/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ─── Catch-all: deny all other reads/writes ────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
