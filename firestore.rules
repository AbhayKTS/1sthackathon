rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Users Collection ───────────────────────────────────────
    // Users can only read and create their own document. Updates are admin-only.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ─── Join Gang Leads (Registration Form) ────────────────────
    // Any authenticated user (including anonymous) can create.
    // No one can read/update/delete from client.
    match /joinGangLeads/{docId} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['name', 'email', 'number', 'teamName'])
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.number is string
        && request.resource.data.teamName is string;
      allow read, update, delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ─── Teams ──────────────────────────────────────────────────
    // Any authenticated user can read. Only admins can write.
    match /teams/{teamId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ─── Rounds ─────────────────────────────────────────────────
    // Any authenticated user can read. Only admins can write.
    match /rounds/{roundId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ─── Announcements ──────────────────────────────────────────
    // Any authenticated user can read. Only admins can create.
    match /announcements/{annId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow update, delete: if false;
    }

    // ─── Submissions ────────────────────────────────────────────
    // Any authenticated (non-anonymous) user can create.
    // Any authenticated user can read. Only admins can update/delete.
    match /submissions/{subId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
      allow update, delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ─── Default: Deny Everything Else ──────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
